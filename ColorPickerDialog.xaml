<Window x:Class="NoBorder.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Pick a color"
        Width="300" Height="500"
        MinWidth="280" MinHeight="460"
        WindowStyle="None"
        Background="{DynamicResource BgBrush}"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/icon.ico">

    <!-- WindowChrome (rather than AllowsTransparency) keeps real edge/corner mouse-resize
         working: AllowsTransparency disables Win32 resize hit-testing entirely, leaving only
         the single corner grip from CanResizeWithGrip, which is awkward for a dialog the user
         is expected to resize freely. CaptionHeight=0 means there's no reserved title-bar
         strip - dragging is instead wired up explicitly on the custom title Grid below via
         the usual MouseLeftButtonDown -> DragMove handler. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="14" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BgBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="18,16,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- title bar -->
                <RowDefinition Height="Auto"/> <!-- saturation/lightness square -->
                <RowDefinition Height="Auto"/> <!-- hue slider -->
                <RowDefinition Height="Auto"/> <!-- preview + hex -->
                <RowDefinition Height="Auto"/> <!-- RGB inputs -->
                <RowDefinition Height="Auto"/> <!-- buttons -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Custom color" Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource ReadoutFont}" FontWeight="SemiBold" FontSize="14"/>
                <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{StaticResource QuietButton}" Padding="5" Click="CancelButton_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <!-- Saturation/Lightness square: hue-tinted, click or drag to pick -->
            <Border Grid.Row="1" Height="180" CornerRadius="8" ClipToBounds="True" Margin="0,0,0,14"
                    MouseLeftButtonDown="SatLightSquare_MouseDown" MouseMove="SatLightSquare_MouseMove"
                    MouseLeftButtonUp="SatLightSquare_MouseUp" Cursor="Cross">
                <Grid x:Name="SatLightSquare">
                    <Rectangle x:Name="HueBackdrop" Fill="Red"/>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#FF000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Canvas>
                        <Ellipse x:Name="SatLightCursor" Width="14" Height="14"
                                 Stroke="White" StrokeThickness="2"
                                 IsHitTestVisible="False"
                                 Canvas.Left="0" Canvas.Top="0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Hue slider -->
            <Border Grid.Row="2" Height="20" CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16"
                    MouseLeftButtonDown="HueSlider_MouseDown" MouseMove="HueSlider_MouseMove"
                    MouseLeftButtonUp="HueSlider_MouseUp" Cursor="Hand">
                <Grid x:Name="HueSliderGrid">
                    <Rectangle x:Name="HueGradientRect"/>
                    <Canvas>
                        <Border x:Name="HueCursor" Width="4" Height="20" Background="White"
                                IsHitTestVisible="False" Canvas.Left="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
                            </Border.Effect>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Preview + hex -->
            <Grid Grid.Row="3" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="PreviewSwatch" Width="40" Height="40" CornerRadius="9"
                        BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1.5"/>
                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="HEX" Style="{StaticResource SectionHeader}" Margin="2,0,0,4"/>
                    <TextBox x:Name="HexInput" Grid.Row="1" Style="{StaticResource DarkTextBox}"
                             TextChanged="HexInput_TextChanged" MaxLength="9"/>
                </Grid>
            </Grid>

            <!-- RGB numeric inputs -->
            <Grid Grid.Row="4" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="R" Style="{StaticResource SectionHeader}" Margin="2,0,0,4"/>
                    <TextBox x:Name="RInput" Style="{StaticResource DarkTextBox}" TextChanged="RgbInput_TextChanged" MaxLength="3"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="G" Style="{StaticResource SectionHeader}" Margin="2,0,0,4"/>
                    <TextBox x:Name="GInput" Style="{StaticResource DarkTextBox}" TextChanged="RgbInput_TextChanged" MaxLength="3"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="B" Style="{StaticResource SectionHeader}" Margin="2,0,0,4"/>
                    <TextBox x:Name="BInput" Style="{StaticResource DarkTextBox}" TextChanged="RgbInput_TextChanged" MaxLength="3"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Style="{StaticResource QuietButton}"
                        HorizontalContentAlignment="Center" Click="CancelButton_Click" Margin="0,0,6,0"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button Grid.Column="1" Content="Use this color" Style="{StaticResource SmallButton}"
                        Click="OkButton_Click" Margin="6,0,0,0"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
