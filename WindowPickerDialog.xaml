<Window x:Class="NoBorder.WindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick a window"
        Width="300" Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/icon.ico">

    <Border Background="{DynamicResource BgBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="18,16,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Choose a window to exclude" Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource ReadoutFont}" FontWeight="SemiBold" FontSize="14"/>
                <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Style="{StaticResource QuietButton}" Padding="5" Click="CancelButton_Click"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="Excludes by process name, so all windows from that app are skipped."
                       Style="{StaticResource LabelMuted}" TextWrapping="Wrap" Margin="0,4,0,10"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="WindowList"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
