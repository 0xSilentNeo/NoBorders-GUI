<Window x:Class="NoBorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoBorder"
        Width="320" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="False"
        Icon="pack://application:,,,/Resources/icon.ico">

    <Border Background="{DynamicResource BgBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.35" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="20,18,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- title bar -->
                <RowDefinition Height="Auto"/> <!-- tab switcher -->
                <RowDefinition Height="*"/>    <!-- page content (Home or Settings) -->
                <RowDefinition Height="Auto"/> <!-- footer -->
            </Grid.RowDefinitions>

            <!-- Title bar: draggable, with close button -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Margin="0,0,0,12"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="NoBorder" Foreground="{DynamicResource TextBrush}"
                           FontFamily="{StaticResource ReadoutFont}" FontWeight="SemiBold" FontSize="15"
                           Background="Transparent" IsHitTestVisible="True"/>
                <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                        Style="{StaticResource QuietButton}" Padding="6"
                        Click="HideButton_Click" ToolTip="Close to tray"/>
            </Grid>

            <!-- Tab switcher -->
            <Border Grid.Row="1" Background="{DynamicResource BgRaisedBrush}" CornerRadius="9" Padding="3" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="HomeTabButton" Grid.Column="0" Content="Home"
                                  Style="{StaticResource TabButton}" IsChecked="True" Click="HomeTabButton_Click"/>
                    <ToggleButton x:Name="SettingsTabButton" Grid.Column="1" Content="Settings"
                                  Style="{StaticResource TabButton}" Click="SettingsTabButton_Click"/>
                </Grid>
            </Border>

            <!-- Home page -->
            <Grid x:Name="HomePage" Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- signature visual -->
                    <RowDefinition Height="Auto"/> <!-- status line -->
                    <RowDefinition Height="Auto"/> <!-- toggle row -->
                    <RowDefinition Height="Auto"/> <!-- divider -->
                    <RowDefinition Height="Auto"/> <!-- secondary actions -->
                    <RowDefinition Height="Auto"/> <!-- divider -->
                    <RowDefinition Height="Auto"/> <!-- startup toggle -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Signature visual: a mock window corner whose border dissolves -->
                <Viewbox Grid.Row="0" Height="92" Margin="0,0,0,16" Stretch="Uniform">
                    <Canvas Width="260" Height="92">
                        <Rectangle x:Name="WinA" Canvas.Left="8" Canvas.Top="8" Width="118" Height="76"
                                   RadiusX="6" RadiusY="6" Fill="{DynamicResource BgRaisedBrush}"
                                   Stroke="{DynamicResource StrokeBrush}" StrokeThickness="1"/>
                        <Rectangle x:Name="WinB" Canvas.Left="134" Canvas.Top="8" Width="118" Height="76"
                                   RadiusX="6" RadiusY="6" Fill="{DynamicResource BgRaisedBrush}"
                                   Stroke="{DynamicResource StrokeBrush}" StrokeThickness="1"/>
                        <Rectangle x:Name="Seam" Canvas.Left="126" Canvas.Top="8" Width="8" Height="76"
                                   Fill="#D8DADD" Opacity="1"/>
                    </Canvas>
                </Viewbox>

                <!-- Status line -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Not watching" Foreground="{DynamicResource TextBrush}"
                               FontFamily="{StaticResource ReadoutFont}" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Toggle row -->
                <Border Grid.Row="2" Background="{DynamicResource BgRaisedBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Watch for new windows" Style="{StaticResource BodyText}"/>
                            <TextBlock Text="Keeps borders off as you open and snap windows" Style="{StaticResource LabelMuted}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton x:Name="WatchToggle" Grid.Column="1" Style="{StaticResource ToggleButtonPill}"
                                      VerticalAlignment="Center" Checked="WatchToggle_Checked" Unchecked="WatchToggle_Unchecked"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Height="1" Background="{DynamicResource StrokeBrush}" Margin="0,0,0,8"/>

                <!-- Secondary actions -->
                <StackPanel Grid.Row="4" Margin="0,0,0,8">
                    <Button Content="Fix open windows once" Style="{StaticResource QuietButton}" Click="ApplyOnceButton_Click" HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Border Grid.Row="5" Height="1" Background="{DynamicResource StrokeBrush}" Margin="0,0,0,10"/>

                <!-- Startup -->
                <Border Grid.Row="6" Background="{DynamicResource BgRaisedBrush}" CornerRadius="10" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Start automatically on startup" Style="{StaticResource BodyText}"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <ToggleButton x:Name="StartupToggle" Grid.Column="1" Style="{StaticResource ToggleButtonPill}"
                                      VerticalAlignment="Center" Checked="StartupCheckBox_Checked" Unchecked="StartupCheckBox_Unchecked"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Settings page: SettingsView is instantiated in code-behind (it needs
                 constructor args) and inserted into this placeholder. -->
            <ContentControl x:Name="SettingsPageHost" Grid.Row="2" Visibility="Collapsed"/>

            <!-- Footer -->
            <TextBlock x:Name="FooterText" Grid.Row="3" Style="{StaticResource LabelMuted}"
                       Text="" HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
